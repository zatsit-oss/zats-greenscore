---
import {formatDate} from "../utils/ui";

interface Props {
    isCompleted?: boolean;
}

const {isCompleted = false} = Astro.props;

// Default values for server-side rendering (will be updated by JS)
const date = formatDate(new Date().toISOString());

// Dynamic Classes for status badge
let statusClasses =
    "status-badge text-xs px-3 py-1 rounded-full font-semibold uppercase tracking-wider border";
if (isCompleted) {
    statusClasses +=
        " bg-emerald-500/10 text-[var(--color-status-completed)] border-emerald-500/20";
} else {
    statusClasses += " bg-amber-500/10 text-[var(--color-status-inprogress)] border-amber-500/20";
}

const linkHref = "#";
---

<div
        class="project-card relative flex flex-col h-full p-6 rounded-xl bg-[var(--glass-bg)] backdrop-blur-md border border-[var(--glass-border)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg hover:border-[var(--color-primary)]"
        data-project-id=""
>
    <div class="flex justify-between items-start mb-4">
        <div class="flex items-center gap-2">
            <div class={statusClasses}>
                {isCompleted ? "Completed" : "In Progress"}
            </div>
            <span class="progress-counter hidden text-sm text-[var(--color-text-muted)] font-medium tabular-nums"></span>
        </div>
        <!-- Scores container - shows all completed evaluations -->
        <div class="scores-container flex gap-2">
            <!-- API Green Score badge (hidden by default, shown via JS) -->
            <div class="score-item score-apigreenscore hidden flex flex-col items-center"
                 data-eval-type="apigreenscore">
                <div
                        class="score-badge w-10 h-10 rounded-full bg-white/5 border-2 flex items-center justify-center text-sm font-bold"
                        aria-label="API Green Score: not calculated"
                >
                    --
                </div>
                <span class="score-label text-[10px] text-[var(--color-text-muted)] mt-1 font-medium"
                      aria-hidden="true">GS</span>
            </div>
            <!-- EROOM badge (hidden by default, shown via JS) -->
            <div class="score-item score-eroom hidden flex flex-col items-center" data-eval-type="eroom">
                <div
                        class="score-badge w-10 h-10 rounded-full bg-white/5 border-2 flex items-center justify-center text-sm font-bold"
                        aria-label="EROOM Score: not calculated"
                >
                    --
                </div>
                <span class="score-label text-[10px] text-[var(--color-text-muted)] mt-1 font-medium"
                      aria-hidden="true">EROOM</span>
            </div>
            <!-- Pending badge (shown when no completed evaluation) -->
            <div class="score-pending flex flex-col items-center">
                <div class="w-10 h-10 rounded-full bg-white/5 border-2 border-dashed border-slate-400 flex items-center justify-center text-slate-400 text-sm font-bold"
                     aria-label="No score yet">
                    --
                </div>
                <span class="text-[10px] text-[var(--color-text-muted)] mt-1" aria-hidden="true">Score</span>
            </div>
        </div>
    </div>
    <h2
            class="project-name text-xl font-semibold mb-2 text-[var(--color-text)]"
    >
        Project Name
    </h2>
    <p
            class="project-desc text-sm text-[var(--color-text-muted)] leading-relaxed mb-6 line-clamp-2 overflow-hidden"
    >
        Description
    </p>
    <div
            class="mt-auto pt-4 border-t border-[var(--color-border)] flex justify-between items-center"
    >
        <span class="text-xs text-[var(--color-text-muted)]">
            Updated <span class="project-date">{date}</span>
        </span>
        <div class="flex items-center gap-3">
            <button
                    class="delete-project-btn relative z-10 p-1.5 rounded text-[var(--color-text-muted)] hover:text-red-500 hover:bg-red-500/10 transition-colors focus:outline-none focus:ring-2 focus:ring-red-500"
                    aria-label="Delete this project"
            >
                <svg xmlns="http://www.w3.org/2000/svg" style="width: 16px; height: 16px;" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
            </button>
            <span
                    class="action-text text-sm font-medium text-[var(--color-primary)]"
                    aria-hidden="true"
            >
                {isCompleted ? "View Details →" : "View Project →"}
            </span>
        </div>
    </div>
    <!-- Stretched link covering the entire card -->
    <a
            href={linkHref}
            class="project-card-link absolute inset-0 z-0"
            aria-label={isCompleted ? "View project details" : "View project"}
    >
        <span class="sr-only">{isCompleted ? "View Details" : "View Project"}</span>
    </a>
</div>
