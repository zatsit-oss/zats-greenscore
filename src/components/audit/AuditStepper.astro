---
interface Props {
    sections: Record<string, any[]>;
}

const { sections } = Astro.props;
const sectionNames = Object.keys(sections);
const totalSections = sectionNames.length;
---

<nav class="mb-8" aria-label="Audit progress">
    <!-- Desktop: Full stepper -->
    <div class="hidden md:flex justify-between relative">
        <div
            class="absolute top-6 left-0 right-0 h-0.5 bg-[var(--color-border)] z-0 -translate-y-1/2"
            aria-hidden="true"
        >
        </div>
        {
            sectionNames.map((sectionName, index) => (
                <div
                    class="step-item relative z-10 flex flex-col items-center gap-2 bg-[var(--color-bg)] px-2 cursor-pointer"
                    data-step={index}
                    data-section-name={sectionName}
                    role="button"
                    tabindex="0"
                    aria-label={`Go to ${sectionName}`}
                    aria-current={index === 0 ? "step" : undefined}
                >
                    <div class="step-circle w-12 h-12 rounded-full bg-[var(--color-surface)] border-2 border-[var(--color-border)] flex items-center justify-center font-bold text-[var(--color-text-muted)] transition-all duration-300">
                        {index + 1}
                    </div>
                    <span
                        class="step-progress-count text-[10px] font-medium text-[var(--color-text-muted)] tabular-nums"
                        data-section-name={sectionName}
                        data-total={sections[sectionName].length}
                    >
                        0/{sections[sectionName].length}
                    </span>
                    <span class="step-label text-sm font-medium text-[var(--color-text-muted)] transition-colors duration-300">
                        {sectionName}
                    </span>
                </div>
            ))
        }
    </div>

    <!-- Mobile: Compact progress -->
    <div class="md:hidden">
        <div class="flex items-center justify-between mb-2">
            <span class="step-current-label text-sm font-medium text-[var(--color-primary)]">
                {sectionNames[0]}
            </span>
            <span class="step-progress text-sm text-[var(--color-text-muted)]" aria-live="polite">
                <span class="sr-only">Step</span> 1 / {totalSections}
            </span>
        </div>
        <div
            class="h-2 bg-[var(--color-surface)] rounded-full overflow-hidden"
            role="progressbar"
            aria-valuenow={1}
            aria-valuemin={1}
            aria-valuemax={totalSections}
            aria-label="Audit progress"
        >
            <div
                class="step-progress-bar h-full bg-[var(--color-primary)] transition-all duration-300"
                style={`width: ${(1 / totalSections) * 100}%`}
            ></div>
        </div>
    </div>
</nav>

<style>
    /* Active State */
    .step-item.active .step-circle {
        border-color: #2563eb;
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.15);
        transform: scale(1.1);
    }

    .step-item.active .step-label {
        color: #2563eb;
        font-weight: 700;
    }

    /* Completed State */
    .step-item.completed .step-circle {
        border-color: #f59e0b;
    }

    .step-item.completed .step-label {
        color: var(--color-text);
    }
</style>
