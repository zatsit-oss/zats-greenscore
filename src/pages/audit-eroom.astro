---
import Layout from "../layouts/Layout.astro";
import eroomData from "../data/eroom-data-model-1-1.json";
import AuditStepper from "../components/audit/AuditStepper.astro";
import type {AuditStep} from "../components/audit/AuditStepper.astro";
import EroomSection from "../components/audit/eroom/EroomSection.astro";
import AuditNavigation from "../components/audit/AuditNavigation.astro";
import {EvaluationType, EVALUATION_TYPES} from "../types/evaluation";
import type {EroomCategory} from "../types/eroom";

// Get categories from EROOM data
const categories = eroomData.categories as EroomCategory[];

const urlParams = new URLSearchParams(Astro.url.search);
const projectId = urlParams.get("projectId");
const evaluationType = EvaluationType.EROOM;
const evaluationInfo = EVALUATION_TYPES[evaluationType];

const auditSteps: AuditStep[] = categories.map((category) => ({
    label: category.name,
    icon: category.icon,
    variant: category.includeInScore ? 'default' : 'highlight' as const,
    progress: { total: category.questions.length, dataId: category.id },
}));
---

<Layout title={`Audit - ${evaluationInfo.name}`}>
    <div class="max-w-4xl mx-auto">
        <div class="mb-8">
            <a
                    href="/"
                    class="link-back mb-4"
            >
                &larr; Back to Dashboard
            </a>
            <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-3">
                    <h1 class="text-3xl font-bold text-[var(--color-text)]">
                        Audit
                    </h1>
                    <span class="px-3 py-1 text-sm rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] font-medium">
            {evaluationInfo.name}
          </span>
                </div>
                <span id="progressCounter" class="text-base font-medium text-[var(--color-text-muted)] tabular-nums">
          Answers: 0/0
        </span>
            </div>
            <p class="text-muted">
                Evaluate the optimization potential of your digital service. Your progress is saved automatically.
            </p>
        </div>

        <!-- Stepper -->
        <AuditStepper steps={auditSteps} ariaLabel="EROOM audit progress" />

        <form class="flex flex-col gap-8 pb-24" id="auditForm" data-project-id={projectId}
              data-evaluation-type={evaluationType}>
            {categories.map((category, index) => (
                    <EroomSection
                            category={category}
                            index={index}
                    />
            ))}

            <AuditNavigation/>
        </form>
    </div>

    <!-- Quick Diagnosis: Intro Modal -->
    <div id="introModal"
         class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm"
         role="dialog" aria-modal="true" aria-labelledby="introModalTitle">
        <div class="glass-card max-w-lg w-full mx-4 p-6" role="document">
            <h2 id="introModalTitle" class="text-xl font-bold mb-3">Quick Diagnosis</h2>
            <p class="text-muted mb-2">
                Before diving into the detailed evaluation, start with the <strong>quick diagnosis</strong>.
            </p>
            <p class="text-muted mb-2">
                Rate each question from 1 to 5 based on available information:
            </p>
            <ul class="text-sm text-muted mb-4 list-disc pl-5 space-y-1">
                <li><strong>1</strong> = not mastered / unknown</li>
                <li><strong>5</strong> = mastered, measured, optimized</li>
            </ul>
            <p class="text-sm text-muted mb-6">
                If the quick score is very low, a detailed evaluation may not be necessary.
            </p>
            <div class="flex justify-end">
                <button class="btn btn-primary" id="introModalClose">Start Quick Diagnosis</button>
            </div>
        </div>
    </div>

    <!-- Quick Diagnosis: Result Modal -->
    <div id="quickResultModal"
         class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm"
         role="dialog" aria-modal="true" aria-labelledby="quickResultTitle">
        <div class="glass-card max-w-md w-full mx-4 p-6 text-center" role="document">
            <h2 id="quickResultTitle" class="text-xl font-bold mb-4">Quick Diagnosis Result</h2>
            <div class="flex justify-center mb-4">
                <div class="w-24 h-24 rounded-full border-6 flex items-center justify-center bg-white/5"
                     id="quickResultCircle">
                    <span class="text-4xl font-extrabold" id="quickResultScore">--</span>
                </div>
            </div>
            <p class="text-sm text-muted mb-1" id="quickResultLabel">Level</p>
            <p class="text-sm text-muted mt-3 leading-relaxed" id="quickResultRecommendation"></p>
            <div class="flex justify-center gap-3 mt-6">
                <a id="quickResultBackLink" href="/" class="btn btn-secondary">Back to Project</a>
                <button class="btn btn-primary" id="quickResultContinue">Continue Advanced Diagnosis</button>
            </div>
        </div>
    </div>
</Layout>

<script>
    import {EvaluationType, EVALUATION_TYPES} from "../types/evaluation";
    import {saveEroomProgressiveScore, saveEroomPreliminaryScore, finalizeEroomEvaluation, getScoreDetailsByType} from "../services/evaluation-service";
    import {getProject} from "../services/project-service";
    import {validateEroomCompletion, calculateQuickDiagnosisScore} from "../utils/eroom-scoring";
    import type {EroomCategory, EroomAnswerValue} from "../types/eroom";
    import eroomData from "../data/eroom-data-model-1-1.json";
    import {showToast} from "../utils/toast";

    const categories = eroomData.categories as EroomCategory[];
    const preliminaryConfig = EVALUATION_TYPES[EvaluationType.EROOM].preliminary!;
    const preliminaryCategory = categories.find(c => !c.includeInScore)!;
    const progressCounter = document.getElementById("progressCounter");

    let currentStep = 0;
    const steps = document.querySelectorAll(".step-content");
    const stepItems = document.querySelectorAll(".step-item");
    const prevBtn = document.getElementById("prevBtn");
    const nextBtn = document.getElementById("nextBtn");
    const submitBtn = document.getElementById("submitBtn");
    const totalSteps = steps.length;

    // Mobile progress elements
    const stepCurrentLabel = document.querySelector(".step-current-label");
    const stepProgress = document.querySelector(".step-progress");
    const stepProgressBar = document.querySelector(".step-progress-bar") as HTMLElement;

    function updateUI() {
        // Show/Hide steps
        steps.forEach((step, index) => {
            (step as HTMLElement).style.display = index === currentStep ? "block" : "none";
        });

        // Update Stepper (desktop)
        stepItems.forEach((item, index) => {
            item.classList.remove("active", "completed");
            item.removeAttribute("aria-current");
            if (index === currentStep) {
                item.classList.add("active");
                item.setAttribute("aria-current", "step");
            } else if (index < currentStep) {
                item.classList.add("completed");
            }
        });

        // Update mobile progress
        if (stepCurrentLabel && categories[currentStep]) {
            stepCurrentLabel.textContent = '';
            const iconSpan = document.createElement('span');
            iconSpan.setAttribute('aria-hidden', 'true');
            iconSpan.textContent = categories[currentStep].icon;
            stepCurrentLabel.appendChild(iconSpan);
            stepCurrentLabel.appendChild(document.createTextNode(` ${categories[currentStep].name}`));
        }
        if (stepProgress) {
            stepProgress.textContent = '';
            const srSpan = document.createElement('span');
            srSpan.className = 'sr-only';
            srSpan.textContent = 'Step';
            stepProgress.appendChild(srSpan);
            stepProgress.appendChild(document.createTextNode(` ${currentStep + 1} / ${totalSteps}`));
        }
        if (stepProgressBar) {
            stepProgressBar.style.width = `${((currentStep + 1) / totalSteps) * 100}%`;
        }
        const progressBarContainer = stepProgressBar?.parentElement;
        if (progressBarContainer) {
            progressBarContainer.setAttribute("aria-valuenow", String(currentStep + 1));
        }

        // Update Buttons
        if (prevBtn) prevBtn.style.display = currentStep === 0 ? "none" : "block";

        if (currentStep === totalSteps - 1) {
            if (nextBtn) nextBtn.style.display = "none";
            if (submitBtn) submitBtn.style.display = "block";
        } else {
            if (nextBtn) {
                nextBtn.style.display = "block";
                // Step 0 = quick diagnosis → special label
                nextBtn.textContent = currentStep === 0 ? 'Quick Evaluate' : 'Next';
            }
            if (submitBtn) submitBtn.style.display = "none";
        }

        // Scroll to top
        window.scrollTo({top: 0, behavior: "smooth"});
    }

    // ========================================================================
    // QUICK DIAGNOSIS MODALS
    // ========================================================================

    const introModal = document.getElementById("introModal");
    const introModalClose = document.getElementById("introModalClose");
    const quickResultModal = document.getElementById("quickResultModal");
    const quickResultContinue = document.getElementById("quickResultContinue");
    const quickResultBackLink = document.getElementById("quickResultBackLink") as HTMLAnchorElement | null;

    // Set back link to project view
    const urlParamsClient = new URLSearchParams(window.location.search);
    const projectIdParam = urlParamsClient.get("projectId");
    if (quickResultBackLink && projectIdParam) {
        quickResultBackLink.href = `/projects/view?id=${projectIdParam}&evaluationType=eroom`;
    }

    /**
     * Show the quick diagnosis result modal with score and recommendation
     */
    function showQuickResultModal() {
        const answers = collectAnswers();
        const { score } = calculateQuickDiagnosisScore(answers, preliminaryCategory.questions);
        const details = getScoreDetailsByType(score, EvaluationType.EROOM);

        // Determine recommendation from config thresholds
        let recommendation: string;
        if (score <= preliminaryConfig.thresholds.low) {
            recommendation = preliminaryConfig.recommendations.low;
        } else if (score <= preliminaryConfig.thresholds.high) {
            recommendation = preliminaryConfig.recommendations.medium;
        } else {
            recommendation = preliminaryConfig.recommendations.high;
        }

        // Update modal content
        const scoreEl = document.getElementById("quickResultScore");
        const circleEl = document.getElementById("quickResultCircle");
        const labelEl = document.getElementById("quickResultLabel");
        const recoEl = document.getElementById("quickResultRecommendation");

        if (scoreEl) scoreEl.textContent = score.toString();
        if (labelEl) labelEl.textContent = details.text;
        if (circleEl) {
            circleEl.style.borderColor = details.color;
            circleEl.style.boxShadow = `0 0 16px ${details.shadow}`;
            circleEl.style.backgroundColor = details.shadow;
        }
        if (recoEl) recoEl.textContent = recommendation;

        // Show modal
        if (quickResultModal) {
            quickResultModal.classList.remove("hidden");
            quickResultModal.classList.add("flex");
            quickResultContinue?.focus();
        }
    }

    // Intro modal: close and focus on first question
    introModalClose?.addEventListener("click", () => {
        if (introModal) {
            introModal.classList.add("hidden");
            introModal.classList.remove("flex");
        }
        // Focus the first interactive element in the audit form
        const firstInput = document.querySelector('.step-content[data-step="0"] input') as HTMLElement | null;
        firstInput?.focus();
    });

    // Quick result modal: continue to advanced diagnosis
    quickResultContinue?.addEventListener("click", () => {
        if (quickResultModal) {
            quickResultModal.classList.add("hidden");
            quickResultModal.classList.remove("flex");
        }
        currentStep = 1;
        updateUI();
    });

    // Next button: intercept at step 0 to show quick result modal
    nextBtn?.addEventListener("click", () => {
        if (currentStep === 0) {
            // Save answers + preliminary score, then show result
            saveAnswers();
            if (projectId) {
                saveEroomPreliminaryScore(projectId, collectAnswers(), categories);
            }
            showQuickResultModal();
            return;
        }
        if (currentStep < totalSteps - 1) {
            currentStep++;
            updateUI();
        }
    });

    prevBtn?.addEventListener("click", () => {
        if (currentStep > 0) {
            currentStep--;
            updateUI();
        }
    });

    // Clickable stepper steps
    stepItems.forEach((item) => {
        const goToStep = () => {
            const step = parseInt(item.getAttribute("data-step") || "0", 10);
            currentStep = step;
            updateUI();
        };
        item.addEventListener("click", goToStep);
        item.addEventListener("keydown", (e) => {
            if ((e as KeyboardEvent).key === "Enter" || (e as KeyboardEvent).key === " ") {
                e.preventDefault();
                goToStep();
            }
        });
    });

    // Initialize
    updateUI();

    const auditForm = document.getElementById("auditForm") as HTMLFormElement;

    // Get params from URL
    const urlParams = new URLSearchParams(window.location.search);
    const projectId = urlParams.get("projectId");
    const evaluationType = EvaluationType.EROOM;

    /**
     * Collect all answers from the form
     */
    const collectAnswers = (): Record<string, EroomAnswerValue> => {
        const answers: Record<string, EroomAnswerValue> = {};
        const radioInputs = auditForm?.querySelectorAll('input[type="radio"]:checked');

        radioInputs?.forEach((radio) => {
            const input = radio as HTMLInputElement;
            // Check if it's a numeric value (Quick Diagnosis)
            const numValue = parseInt(input.value, 10);
            if (!isNaN(numValue)) {
                answers[input.name] = numValue;
            } else {
                answers[input.name] = input.value as EroomAnswerValue;
            }
        });

        return answers;
    };

    /**
     * Check if a single answer counts as "answered"
     */
    const isAnswered = (answer: EroomAnswerValue): boolean => {
        return (
            answer !== null &&
            answer !== undefined &&
            answer !== 'to_evaluate' &&
            answer !== 'evaluation_in_progress'
        );
    };

    // Only scored categories count toward the global progress
    const scoredCategories = categories.filter(c => c.includeInScore);

    /**
     * Update the progress counter display (global + per category)
     */
    const updateProgress = (answers: Record<string, EroomAnswerValue>) => {
        // Global counter: only scored categories
        const scoredValidation = validateEroomCompletion(answers, scoredCategories);
        if (progressCounter) {
            progressCounter.textContent = `Answers: ${scoredValidation.answeredQuestions}/${scoredValidation.totalQuestions}`;
        }

        // Per-category counters in stepper (all categories including Quick Diagnosis)
        categories.forEach((category) => {
            const el = document.querySelector(`.step-progress-count[data-category-id="${category.id}"]`);
            if (!el) return;
            const answered = category.questions.filter(q => isAnswered(answers[q.id])).length;
            el.textContent = `${answered}/${category.questions.length}`;
        });

        // Per-question status icons
        document.querySelectorAll('.question-status').forEach((statusEl) => {
            const qId = statusEl.getAttribute('data-question-id');
            if (!qId) return;
            const answered = isAnswered(answers[qId]);
            const iconPending = statusEl.querySelector('.icon-pending');
            const iconAnswered = statusEl.querySelector('.icon-answered');
            if (iconPending) iconPending.classList.toggle('hidden', answered);
            if (iconAnswered) iconAnswered.classList.toggle('hidden', !answered);
            statusEl.setAttribute('aria-label', answered ? 'Answered' : 'Not answered');
        });
    };

    /**
     * Auto-save answers with progressive score calculation
     */
    const saveAnswers = () => {
        if (!projectId) return;

        const answers = collectAnswers();
        saveEroomProgressiveScore(projectId, evaluationType, answers, categories, scoredCategories);

        // Update counter display
        updateProgress(answers);
    };

    /**
     * Load saved answers
     */
    const loadAnswers = () => {
        if (!projectId) return;

        const project = getProject(projectId);
        if (!project) return;

        const evaluation = project.evaluations[evaluationType];
        if (!evaluation || !evaluation.answers) return;

        Object.entries(evaluation.answers).forEach(([key, value]) => {
            const inputs = auditForm?.querySelectorAll(`input[name="${key}"]`) as NodeListOf<HTMLInputElement>;
            inputs?.forEach((input) => {
                if (input.value === String(value)) {
                    input.checked = true;
                }
            });
        });
    };

    // Attach change listeners for auto-save
    auditForm?.querySelectorAll("input").forEach((input) => {
        input.addEventListener("change", saveAnswers);
    });

    // Load answers on init
    loadAnswers();

    // Check if quick diagnosis was already completed
    const hasPreliminaryScore = (() => {
        if (!projectId) return false;
        const project = getProject(projectId);
        const evaluation = project?.evaluations[evaluationType];
        return evaluation?.preliminaryScore !== undefined && evaluation?.preliminaryScore !== null;
    })();

    if (hasPreliminaryScore) {
        // Skip intro modal and start at step 1 (advanced diagnosis)
        if (introModal) {
            introModal.classList.add("hidden");
            introModal.classList.remove("flex");
        }
        currentStep = 1;
        updateUI();
    }

    // Initialize progress counter
    updateProgress(collectAnswers());

    // Form submission
    auditForm?.addEventListener("submit", (e) => {
        e.preventDefault();

        if (!projectId) {
            showToast("No project ID found. Cannot save.", "error");
            return;
        }

        const answers = collectAnswers();
        const result = finalizeEroomEvaluation(projectId, answers, categories, scoredCategories);

        if (!result.success) {
            showToast(result.message, "error");
            return;
        }

        showToast(result.message, result.isComplete ? "success" : "info");
        setTimeout(() => {
            window.location.href = `/projects/view?id=${projectId}&evaluationType=${evaluationType}`;
        }, 1500);
    });
</script>
