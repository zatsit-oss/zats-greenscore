---
import Layout from '../layouts/Layout.astro';
import aboutContent from '../data/about-content.json';

const {title, subtitle, sections} = aboutContent;

// Pre-process evaluation types to split description around link text (avoids set:html)
const evaluationTypes = sections.evaluationTypes.types.map(
    (type: { name: string; description: string; link: { text: string; url: string } }) => {
        const idx = type.description.indexOf(type.link.text);
        return {
            ...type,
            descBefore: idx >= 0 ? type.description.substring(0, idx) : type.description,
            descAfter: idx >= 0 ? type.description.substring(idx + type.link.text.length) : '',
            hasLink: idx >= 0
        };
    }
);
---

<Layout title="About">
    <div class="max-w-3xl mx-auto">
        <div class="mb-8">
            <a href="/" class="link-back mb-4">
                &larr; Back to Dashboard
            </a>
            <h1 class="text-3xl font-bold mb-4">{title}</h1>
            <p class="text-muted text-lg">{subtitle}</p>
        </div>

        <section class="glass-card mb-8">
            <h2 class="text-xl font-semibold mb-4">{sections.whatIs.title}</h2>
            {sections.whatIs.paragraphs.map((paragraph: string) => (
                    <p class="text-muted leading-relaxed mb-4 last:mb-0">{paragraph}</p>
            ))}
        </section>

        <section class="glass-card mb-8">
            <h2 class="text-xl font-semibold mb-4">{sections.evaluationTypes.title}</h2>
            <div class="space-y-6">
                {evaluationTypes.map((type) => (
                        <div>
                            <h3 class="text-lg font-medium mb-2 text-[var(--color-primary)]">{type.name}</h3>
                            <p class="text-muted leading-relaxed">
                                {type.hasLink ? (
                                        <>
                                            {type.descBefore}
                                            <a href={type.link.url} target="_blank" rel="noopener noreferrer"
                                               class="text-[var(--color-primary)] underline">
                                                {type.link.text}<span class="sr-only"> (opens in new tab)</span>
                                            </a>
                                            {type.descAfter}
                                        </>
                                ) : (
                                    type.description
                                )}
                            </p>
                        </div>
                ))}
            </div>
        </section>

        <section class="glass-card mb-8">
            <h2 class="text-xl font-semibold mb-4">{sections.openSource.title}</h2>
            <p class="text-muted leading-relaxed mb-4">{sections.openSource.description}</p>
            <a
                    href={sections.openSource.github.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn-primary inline-flex items-center gap-2"
                    aria-label={`${sections.openSource.github.text} (opens in new tab)`}
            >
                {sections.openSource.github.text}
                <span class="sr-only">(opens in new tab)</span>
            </a>
        </section>

        <section class="glass-card">
            <h2 class="text-xl font-semibold mb-4">{sections.credits.title}</h2>
            <ul class="text-muted space-y-2">
                {sections.credits.items.map((item: { name: string; url: string; linkText: string; license?: string; licenseUrl?: string; notice?: string }) => (
                        <li>
                            <strong>{item.name}</strong> -{' '}
                            <a
                                    href={item.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-[var(--color-primary)] underline"
                            >
                                {item.linkText}<span class="sr-only"> (opens in new tab)</span>
                            </a>
                            {item.license && item.licenseUrl && (
                                <span>
                                    {' '} — Licensed under{' '}
                                    <a
                                        href={item.licenseUrl}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="text-[var(--color-primary)] underline"
                                    >
                                        {item.license}<span class="sr-only"> (opens in new tab)</span>
                                    </a>
                                </span>
                            )}
                            {item.notice && (
                                <p class="text-sm text-muted mt-1">{item.notice}</p>
                            )}
                        </li>
                ))}
            </ul>
        </section>
    </div>
</Layout>
