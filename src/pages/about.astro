---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
  <div class="max-w-3xl mx-auto">
    <div class="mb-8">
      <a href="/" class="link-back mb-4">
        &larr; Back to Dashboard
      </a>
      <h1 class="text-3xl font-bold mb-4">About Zats Green Score</h1>
      <p class="text-muted text-lg">
        Evaluate the eco-design maturity of your digital projects.
      </p>
    </div>

    <section class="glass-card mb-8">
      <h2 class="text-xl font-semibold mb-4">What is Zats Green Score?</h2>
      <p class="text-muted leading-relaxed mb-4">
        Zats Green Score is an open-source tool for evaluating the environmental impact
        and eco-design practices of digital projects, particularly APIs and web services.
      </p>
      <p class="text-muted leading-relaxed">
        It helps teams identify areas for improvement and track their progress
        toward more sustainable digital practices.
      </p>
    </section>

    <section class="glass-card mb-8">
      <h2 class="text-xl font-semibold mb-4">Evaluation Types</h2>

      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-medium mb-2 text-[var(--color-primary)]">API Green Score</h3>
          <p class="text-muted leading-relaxed">
            Based on the <a href="https://github.com/API-Green-Score/APIGreenScore" target="_blank" rel="noopener noreferrer" class="text-[var(--color-primary)] hover:underline">API Green Score</a> methodology,
            this evaluation focuses on API design best practices for eco-design:
            architecture, data management, caching strategies, and more.
          </p>
        </div>

        <div>
          <h3 class="text-lg font-medium mb-2 text-[var(--color-primary)]">EROOM (EOF v1.1)</h3>
          <p class="text-muted leading-relaxed">
            Based on <a href="https://boavizta.org/" target="_blank" rel="noopener noreferrer" class="text-[var(--color-primary)] hover:underline">Boavizta's</a> EROOM Optimization Framework,
            this evaluation measures the optimization potential of digital services
            across multiple dimensions: product, architecture, infrastructure, and more.
          </p>
        </div>
      </div>
    </section>

    <section class="glass-card mb-8">
      <h2 class="text-xl font-semibold mb-4">Open Source</h2>
      <p class="text-muted leading-relaxed mb-4">
        Zats Green Score is open source and available on GitHub. Contributions are welcome!
      </p>
      <a
        href="https://github.com/zatsit-oss/zats-greenscore"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary inline-flex items-center gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 496 512" class="w-5 h-5" fill="currentColor">
          <path d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3 .3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5 .3-6.2 2.3zm44.2-1.7c-2.9 .7-4.9 2.6-4.6 4.9 .3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8z"/>
        </svg>
        View on GitHub
      </a>
    </section>

    <section class="glass-card">
      <h2 class="text-xl font-semibold mb-4">Credits</h2>
      <ul class="text-muted space-y-2">
        <li>
          <strong>API Green Score</strong> -
          <a href="https://github.com/API-Green-Score/APIGreenScore" target="_blank" rel="noopener noreferrer" class="text-[var(--color-primary)] hover:underline">
            API-Green-Score
          </a>
        </li>
        <li>
          <strong>EROOM Framework</strong> -
          <a href="https://boavizta.org/" target="_blank" rel="noopener noreferrer" class="text-[var(--color-primary)] hover:underline">
            Boavizta
          </a>
        </li>
        <li>
          <strong>Developed by</strong> -
          <a href="https://zatsit.fr/" target="_blank" rel="noopener noreferrer" class="text-[var(--color-primary)] hover:underline">
            Zatsit
          </a>
        </li>
      </ul>
    </section>
  </div>
</Layout>
