---
import Layout from '../../layouts/Layout.astro'
import RadarChart from '../../components/RadarChart.astro'
import {getAvailableEvaluationTypes} from '../../types/evaluation'

const evaluationTypes = getAvailableEvaluationTypes()
---

<Layout title="Project Details">
    <div class="max-w-4xl mx-auto hidden" id="projectContent" aria-live="polite">
        <div class="mb-8">
            <a href="/" class="link-back mb-4">
                &larr; Back to Dashboard
            </a>
            <div class="flex justify-between items-start flex-wrap gap-4">
                <div>
                    <h1 class="text-4xl font-extrabold leading-tight mb-3" id="projectName">
                        Project Name
                    </h1>
                    <!-- Evaluation Type Selector -->
                    <div class="flex items-center gap-3">
                        <label for="evaluationTypeSelect" class="text-sm font-medium text-muted">
                            Evaluation:
                        </label>
                        <select id="evaluationTypeSelect" class="form-select">
                            {evaluationTypes.map((evalType) => (
                                    <option value={evalType.id}>
                                        {evalType.name}
                                    </option>
                            ))}
                        </select>
                    </div>
                </div>
                <div class="flex gap-4 items-center">
                    <span class="status-badge" id="projectStatus">Status</span>
                    <span id="progressCounter"
                          class="hidden text-base text-[var(--color-text-muted)] font-medium tabular-nums"></span>
                    <button class="btn btn-secondary hidden" id="editBtn">Edit Evaluation</button>
                    <button class="btn btn-danger hidden" id="deleteBtn" aria-label="Delete project">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                             stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="md:col-span-2 space-y-8">
                <div class="glass-card">
                    <h2 class="text-xl font-semibold mb-4">About this Project</h2>
                    <p class="text-muted leading-relaxed" id="projectDescription">
                        Description...
                    </p>
                </div>

                <div class="glass-card">
                    <h2 class="text-xl font-semibold mb-4">Timeline</h2>
                    <div class="flex gap-8 mt-6">
                        <div class="flex flex-col">
                            <span class="text-xs text-muted uppercase tracking-wider mb-1">Created</span>
                            <span class="font-medium" id="dateCreated">Oct 1, 2023</span>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-xs text-muted uppercase tracking-wider mb-1">Last Updated</span>
                            <span class="font-medium" id="dateUpdated">Oct 1, 2023</span>
                        </div>
                    </div>
                </div>

                <!-- Score by Section Chart -->
                <div class="glass-card hidden" id="chartCard">
                    <h2 class="text-xl font-semibold mb-4">Score by Section</h2>
                    <RadarChart id="sectionRadarChart"/>
                </div>
            </div>

            <div class="md:col-span-1">
                <div class="glass-card text-center">
                    <h3 class="text-base font-medium text-muted mb-4" id="scoreTitle">Current Score</h3>
                    <div class="flex justify-center mb-4">
                        <div
                                class="w-32 h-32 rounded-full border-8 flex items-center justify-center bg-white/5 shadow-[0_0_20px_rgba(0,0,0,0.1)]"
                                id="scoreCircle"
                        >
                            <span class="text-5xl font-extrabold" id="projectScore">--</span>
                        </div>
                    </div>
                    <p class="text-sm text-muted" id="scoreLabel">Level</p>
                    <p class="text-xs text-muted mt-2 hidden" id="scoreContext"></p>
                </div>
            </div>
        </div>
    </div>

    <div id="loadingState" class="text-center py-20">
        <p class="text-[var(--color-text-muted)]">Loading project details...</p>
    </div>

    <div id="errorState" class="hidden text-center py-20">
        <h1 class="text-2xl font-bold text-[var(--color-text)] mb-4">
            Project Not Found
        </h1>
        <p class="text-[var(--color-text-muted)] mb-8">
            The project you are looking for does not exist or has been removed.
        </p>
        <a
                href="/"
                class="px-4 py-2 rounded-lg font-medium bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-hover)] transition-all"
        >
            Back to Dashboard
        </a>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm"
         role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle" aria-describedby="deleteModalDesc">
        <div class="glass-card max-w-md w-full mx-4 p-6" role="document">
            <h2 id="deleteModalTitle" class="text-xl font-bold mb-4">Delete Project?</h2>
            <p id="deleteModalDesc" class="text-muted mb-2">
                Are you sure you want to delete
                <span class="font-semibold text-[var(--color-text)]" id="deleteProjectName">"Project Name"</span>?
            </p>
            <p class="text-sm text-red-400 mb-6">This action cannot be undone.</p>
            <div class="flex gap-4 justify-end">
                <button class="btn btn-secondary" id="cancelDeleteBtn">Cancel</button>
                <button class="btn btn-danger focus:ring-red-500" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</Layout>

<script>
    import { getProject, deleteProject } from '../../services/project-service'
        import { EvaluationType } from '../../types/evaluation'
        import type { Project } from '../../types/project'
        import { getInitialEvaluationType, getEvaluationDisplayData, ensureEvaluationExists } from '../../services/project-view-service'
        // Data imports for chart preparation
        import type { Question } from '../../types/apigreenscore'
        import surveyQuestions from '../../data/apigreenscore-survey-questions.json'
        import type { EroomCategory } from '../../types/eroom'
        import eroomData from '../../data/eroom-data-model-1-1.json'

        declare global {
            interface Window {
                initRadarChart?: (canvasId: string, data: Array<{ label: string; score: number }>) => void;
                }
            }

        const eroomCategories = eroomData.categories as EroomCategory[]

        // DOM Elements
        const evalTypeSelect = document.getElementById('evaluationTypeSelect') as HTMLSelectElement
        const statusEl = document.getElementById('projectStatus')
        const progressCounterEl = document.getElementById('progressCounter')
        const scoreTitleEl = document.getElementById('scoreTitle')
        const scoreEl = document.getElementById('projectScore')
        const scoreLabelEl = document.getElementById('scoreLabel')
        const scoreCircleEl = document.getElementById('scoreCircle')
        const scoreContextEl = document.getElementById('scoreContext')
        const chartCard = document.getElementById('chartCard')
        const deleteBtn = document.getElementById('deleteBtn')
        const deleteModal = document.getElementById('deleteModal')
        const deleteProjectNameEl = document.getElementById('deleteProjectName')
        const cancelDeleteBtn = document.getElementById('cancelDeleteBtn')
        const confirmDeleteBtn = document.getElementById('confirmDeleteBtn')

        // URL params
        const urlParams = new URLSearchParams(window.location.search)
        const projectId = urlParams.get('id')
        const requestedEvalType = urlParams.get('evaluationType') as EvaluationType | null

        // Helpers
        const formatDate = (dateString: string) => {
            if (!dateString) return 'N/A'
            return new Date(dateString).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
                })
            }

        /**
            * Update the UI for a specific evaluation type
            */
            const updateEvaluationDisplay = (project: Project, evalType: EvaluationType) => {
            const displayData = getEvaluationDisplayData(
                project,
                evalType,
                surveyQuestions as Question[],
                eroomCategories
            )

            // Score Title
            if (scoreTitleEl) {
                scoreTitleEl.textContent = displayData.scoreTitle
                }

            // Status Badge
            if (statusEl) {
                statusEl.textContent = displayData.status
                let statusClasses = 'text-sm px-3 py-1 rounded-full font-semibold uppercase tracking-wider border'
                if (displayData.status === 'Completed') {
                    statusClasses += ' bg-emerald-500/10 text-[var(--color-status-completed)] border-emerald-500/20'
                } else if (displayData.status === 'In Progress') {
                    statusClasses += ' bg-amber-500/10 text-[var(--color-status-inprogress)] border-amber-500/20'
                } else {
                    statusClasses += ' bg-slate-500/10 text-[var(--color-text-muted)] border-slate-500/20'
                }
                statusEl.className = statusClasses
                }

            // Progress counter
            if (progressCounterEl) {
                if (displayData.progress) {
                    progressCounterEl.textContent = `Answers: ${displayData.progress.answered}/${displayData.progress.total}`;
                    progressCounterEl.classList.remove('hidden');
                    } else {
                    progressCounterEl.classList.add('hidden');
                    }
                }

            // Score
            if (scoreEl && scoreLabelEl && scoreCircleEl) {
                if (displayData.score !== null && displayData.scoreDetails) {
                    scoreEl.textContent = displayData.score.toString()
                    scoreLabelEl.textContent = displayData.scoreDetails.text
                    scoreCircleEl.style.borderColor = displayData.scoreDetails.color
                    scoreCircleEl.style.boxShadow = `0 0 20px ${displayData.scoreDetails.shadow}`
                    scoreCircleEl.style.backgroundColor = displayData.scoreDetails.shadow
                    } else {
                    scoreEl.textContent = '--'
                    scoreLabelEl.textContent = displayData.evaluation ? 'Not Calculated' : 'Not Started'
                    scoreCircleEl.style.borderColor = '#94a3b8'
                    scoreCircleEl.style.boxShadow = 'none'
                    scoreCircleEl.style.backgroundColor = 'transparent'
                    }
                }

            // Score context
            if (scoreContextEl) {
                if (displayData.scoreContext) {
                    scoreContextEl.textContent = displayData.scoreContext
                    scoreContextEl.classList.remove('hidden')
                    } else {
                    scoreContextEl.classList.add('hidden')
                    }
                }

            // Radar Chart
            if (chartCard) {
                if (displayData.chartData.length > 0) {
                    chartCard.classList.remove('hidden')
                    requestAnimationFrame(() => {
                        if (typeof window.initRadarChart === 'function') {
                            window.initRadarChart('sectionRadarChart', displayData.chartData)
                            }
                        })
                    } else {
                    chartCard.classList.add('hidden')
                    }
                }

            // Edit Button
            const currentEditBtn = document.getElementById('editBtn') as HTMLButtonElement | null
            if (currentEditBtn) {
                currentEditBtn.classList.remove('hidden')
                currentEditBtn.textContent = displayData.editButtonText

                // Remove old listeners by cloning and replacing
                const newEditBtn = currentEditBtn.cloneNode(true) as HTMLButtonElement
                currentEditBtn.parentNode?.replaceChild(newEditBtn, currentEditBtn)

                newEditBtn.addEventListener('click', () => {
                    ensureEvaluationExists(project.id, evalType)
                    window.location.href = displayData.auditPageUrl
                    })
                }

            // Update URL without reload
            const newUrl = new URL(window.location.href)
            newUrl.searchParams.set('evaluationType', evalType)
            window.history.replaceState({}, '', newUrl.toString())
            }

        // Main logic
        if (!projectId) {
            document.getElementById('loadingState')!.style.display = 'none'
            document.getElementById('errorState')!.classList.remove('hidden')
            } else {
            const project = getProject(projectId)

            if (project) {
                const initialEvalType = getInitialEvaluationType(project, requestedEvalType)

                // Update static project info
                document.title = `${project.name} - Project Details`
                document.getElementById('projectName')!.textContent = project.name
                document.getElementById('projectDescription')!.textContent =
                    project.description || 'No description provided.'
                document.getElementById('dateCreated')!.textContent = formatDate(project.createdAt)
                document.getElementById('dateUpdated')!.textContent = formatDate(project.updatedAt)

                // Set initial select value
                if (evalTypeSelect) {
                    evalTypeSelect.value = initialEvalType

                    evalTypeSelect.addEventListener('change', () => {
                        const selectedType = evalTypeSelect.value as EvaluationType
                        updateEvaluationDisplay(project, selectedType)
                        })
                    }

                // Initial display
                updateEvaluationDisplay(project, initialEvalType)

                // Delete button setup
                if (deleteBtn && deleteModal && deleteProjectNameEl && cancelDeleteBtn && confirmDeleteBtn) {
                    deleteBtn.classList.remove('hidden')

                    let previouslyFocusedElement: HTMLElement | null = null

                    deleteBtn.addEventListener('click', () => {
                        previouslyFocusedElement = document.activeElement as HTMLElement
                        deleteProjectNameEl.textContent = `"${project.name}"`
                        deleteModal.classList.remove('hidden')
                        deleteModal.classList.add('flex')
                        cancelDeleteBtn.focus()
                        })

                    const closeModal = () => {
                        deleteModal.classList.add('hidden')
                        deleteModal.classList.remove('flex')
                        previouslyFocusedElement?.focus()
                        }

                    cancelDeleteBtn.addEventListener('click', closeModal)

                    deleteModal.addEventListener('click', (e) => {
                        if (e.target === deleteModal) closeModal()
                        })

                    const handleKeyDown = (e: KeyboardEvent) => {
                        if (!deleteModal.classList.contains('flex')) return

                        if (e.key === 'Escape') {
                            closeModal()
                            return
                            }

                        if (e.key === 'Tab') {
                            const focusableElements = deleteModal.querySelectorAll<HTMLElement>(
                                'button:not([disabled]), [href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
                                )
                            const firstElement = focusableElements[0]
                            const lastElement = focusableElements[focusableElements.length - 1]

                            if (e.shiftKey && document.activeElement === firstElement) {
                                e.preventDefault()
                                lastElement?.focus()
                                } else if (!e.shiftKey && document.activeElement === lastElement) {
                                e.preventDefault()
                                firstElement?.focus()
                                }
                            }
                        }

                    document.addEventListener('keydown', handleKeyDown)

                    confirmDeleteBtn.addEventListener('click', () => {
                        deleteProject(project.id)
                        window.location.href = '/'
                        })
                    }

                // Show Content
                document.getElementById('loadingState')!.style.display = 'none'
                document.getElementById('projectContent')!.classList.remove('hidden')
                } else {
                document.getElementById('loadingState')!.style.display = 'none'
                document.getElementById('errorState')!.classList.remove('hidden')
                }
            }
</script>
