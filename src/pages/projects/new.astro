---
import Layout from '../../layouts/Layout.astro'
import { EvaluationType, EVALUATION_TYPES, getAvailableEvaluationTypes } from '../../types/evaluation'

const evaluationTypes = getAvailableEvaluationTypes()
---

<Layout title="New Project">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <a
        href="/"
        class="text-[var(--color-text-muted)] text-sm inline-flex items-center gap-2 mb-4 hover:text-[var(--color-primary)] transition-colors"
      >
        &larr; Back to Dashboard
      </a>
      <h1 class="text-3xl font-bold text-[var(--color-text)] mb-2">
        Add New Project
      </h1>
      <p class="text-[var(--color-text-muted)]">
        Enter the details of the API to be audited.
      </p>
    </div>

    <form
      class="p-6 sm:p-8 rounded-xl bg-[var(--glass-bg)] backdrop-blur-md border border-[var(--glass-border)] flex flex-col gap-6"
      id="createProjectForm"
    >
      <div class="flex flex-col gap-2">
        <label for="name" class="text-sm font-medium text-[var(--color-text-muted)]"
        >Project Name</label
        >
        <input
          type="text"
          id="name"
          name="name"
          class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-3 text-[var(--color-text)] text-base focus:outline-none focus:border-[var(--color-primary)] focus:ring-2 focus:ring-emerald-500/20 transition-colors placeholder:text-[var(--color-text-muted)]"
          placeholder="e.g. Customers API"
          required
        />
      </div>

      <div class="flex flex-col gap-2">
        <label
          for="description"
          class="text-sm font-medium text-[var(--color-text-muted)]"
        >Description</label
        >
        <textarea
          id="description"
          name="description"
          rows="4"
          class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-3 text-[var(--color-text)] text-base focus:outline-none focus:border-[var(--color-primary)] focus:ring-2 focus:ring-emerald-500/20 transition-colors placeholder:text-[var(--color-text-muted)]"
          placeholder="Describe the project goals and impact..."
          required></textarea>
      </div>

      <div class="flex flex-col gap-2">
        <label
          for="evaluationType"
          class="text-sm font-medium text-[var(--color-text-muted)]"
        >Evaluation Type</label
        >
        <select
          id="evaluationType"
          name="evaluationType"
          class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-3 text-[var(--color-text)] text-base focus:outline-none focus:border-[var(--color-primary)] focus:ring-2 focus:ring-emerald-500/20 transition-colors"
          required
        >
          {evaluationTypes.map((evalType) => (
            <option value={evalType.id}>
              {evalType.name}
            </option>
          ))}
        </select>
        <p id="evaluationDescription" class="text-xs text-[var(--color-text-muted)] mt-1">
          {evaluationTypes[0]?.description}
        </p>
      </div>

      <div class="mt-4 flex justify-end gap-4">
        <a
          href="/"
          class="px-4 py-2 rounded-lg font-medium border border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors"
        >Cancel</a
        >
        <button
          type="submit"
          class="px-4 py-2 rounded-lg font-medium bg-[var(--color-primary)] text-[var(--color-on-primary)] hover:bg-[var(--color-primary-hover)] transition-all hover:-translate-y-px"
        >Start Audit
        </button
        >
      </div>
    </form>

    <script>
      import { EvaluationType, EVALUATION_TYPES, createEmptyEvaluation } from '../../types/evaluation'
      import type { Project } from '../../types/project'
      import { saveProject, migrateStorageIfNeeded } from '../../utils/storage'

      // Ensure storage is migrated
      migrateStorageIfNeeded()

      // Evaluation type descriptions
      const descriptions: Record<string, string> = {}
      Object.values(EVALUATION_TYPES).forEach((et) => {
        descriptions[et.id] = et.description
      })

      // Update description when evaluation type changes
      const evalSelect = document.getElementById('evaluationType') as HTMLSelectElement
      const evalDescription = document.getElementById('evaluationDescription')

      evalSelect?.addEventListener('change', () => {
        if (evalDescription) {
          evalDescription.textContent = descriptions[evalSelect.value] || ''
        }
      })

      // Form submission
      const form = document.getElementById('createProjectForm')
      console.log('Form element:', form)
      form?.addEventListener('submit', (e) => {
        e.preventDefault()
        console.log('Form submitted')
        const formData = new FormData(e.target as HTMLFormElement)
        const name = formData.get('name')
        const description = formData.get('description')
        const evaluationType = formData.get('evaluationType') as EvaluationType
        console.log('Form data:', { name, description, evaluationType })

        if (name && description && evaluationType) {
          console.log('Creating project...')
          const id = crypto.randomUUID()
          const now = new Date().toISOString()

          // Create project with evaluation
          const evaluation = createEmptyEvaluation(evaluationType)

          const newProject: Project = {
            id,
            name: name.toString(),
            description: description.toString(),
            createdAt: now,
            updatedAt: now,
            evaluations: {
              [evaluationType]: evaluation
            }
          }

          // Save to localStorage
          saveProject(newProject)

          // Redirect to audit page with project details
          const params = new URLSearchParams()
          params.append('projectId', newProject.id)
          params.append('evaluationType', evaluationType)

          window.location.href = `/audit?${params.toString()}`
        }
      })
    </script>
  </div>
</Layout>
